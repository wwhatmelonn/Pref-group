---
const highlights = [
  "Organize member preferences in one place.",
  "Share decision criteria with the whole group.",
  "Publish the current state without extra hosting."
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pref Group</title>
    <meta
      name="description"
      content="A simple landing page for the Pref Group project."
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe7;
        --surface: rgba(255, 250, 242, 0.86);
        --text: #17301f;
        --muted: #4c6252;
        --accent: #0f7a54;
        --accent-strong: #084c34;
        --line: rgba(23, 48, 31, 0.14);
        --shadow: 0 18px 45px rgba(14, 47, 31, 0.12);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(15, 122, 84, 0.18), transparent 34%),
          radial-gradient(circle at bottom right, rgba(196, 116, 34, 0.18), transparent 32%),
          linear-gradient(180deg, #fffaf3 0%, var(--bg) 100%);
      }

      main {
        width: min(960px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 4rem 0 5rem;
      }

      .hero {
        padding: 2.5rem;
        border: 1px solid var(--line);
        border-radius: 28px;
        background: var(--surface);
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
      }

      .eyebrow {
        margin: 0 0 1rem;
        color: var(--accent);
        font-size: 0.9rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        max-width: 10ch;
        font-size: clamp(3rem, 8vw, 5.8rem);
        line-height: 0.92;
      }

      .lead {
        max-width: 42rem;
        margin: 1.5rem 0 0;
        font-size: clamp(1.05rem, 2.2vw, 1.35rem);
        line-height: 1.7;
        color: var(--muted);
      }

      .grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        margin-top: 2rem;
      }

      .card {
        padding: 1.25rem;
        border: 1px solid var(--line);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.8);
      }

      .card strong {
        display: block;
        margin-bottom: 0.6rem;
        color: var(--accent-strong);
      }

      .footer {
        margin-top: 2rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      @media (max-width: 640px) {
        main {
          padding-top: 1.5rem;
        }

        .hero {
          padding: 1.5rem;
          border-radius: 22px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">GitHub Pages Ready</p>
        <h1>Pref Group</h1>
        <p class="lead">
          This Astro starter gives the repository a real static site target, so the
          existing Pages workflow can install dependencies, build the app, and deploy
          something meaningful.
        </p>

        <div class="grid">
          {highlights.map((highlight, index) => (
            <article class="card">
              <strong>{String(index + 1).padStart(2, "0")}</strong>
              <span>{highlight}</span>
            </article>
          ))}
        </div>

        <p class="footer">
          Next step: replace this placeholder content with the actual group purpose,
          members, and preference collection workflow.
        </p>
      </section>
    </main>
  </body>
</html>
